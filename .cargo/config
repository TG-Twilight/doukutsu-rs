[build]
target = "aarch64-unknown-linux-gnu"

[target.aarch64-unknown-linux-gnu]
linker = "aarch64-unknown-linux-gnu-gcc"
ar = "aarch64-unknown-linux-gnu-ar"
rustflags = [
  "-C", "link-args=-L/usr/aarch64-unknown-linux-gnu/lib",
]

[env]
PKG_CONFIG_PATH = "/usr/aarch64-unknown-linux-gnu/lib/pkgconfig"
PKG_CONFIG_SYSROOT_DIR = "/usr/aarch64-unknown-linux-gnu"

[profile.release]
lto = true
